# Supabase (existing project). Required for container title/MBL persistence.
# Get from: Dashboard → Project Settings → API
SUPABASE_URL=https://xxxxx.supabase.co

# Use ONE of these in Vercel (and locally):
# - SUPABASE_SERVICE_ROLE_KEY = service_role key (recommended; no RLS setup)
# - SUPABASE_ANON_KEY        = anon key (you must add RLS policy on container_cost.containers)
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# SUPABASE_ANON_KEY=eyJ...

# Optional: local API server port (default 3001)
# PORT=3001
